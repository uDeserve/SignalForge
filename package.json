{
  "name": "feedbackmesh",
  "private": true,
  "version": "0.1.0",
  "description": "AI-native feedback-to-issue harness that turns user feedback and runtime pain into decision-ready GitHub issues.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uDeserve/FeedbackMesh.git"
  },
  "homepage": "https://github.com/uDeserve/FeedbackMesh",
  "bugs": {
    "url": "https://github.com/uDeserve/FeedbackMesh/issues"
  },
  "keywords": [
    "ai-native",
    "feedback-to-issue",
    "case-intelligence",
    "github-issues",
    "github-app",
    "product-feedback",
    "user-feedback",
    "triage",
    "issue-automation",
    "coding-agents",
    "developer-tools",
    "web-app"
  ],
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "fm:init": "node scripts/feedbackmesh_cli.mjs init",
    "fm:doctor": "node scripts/feedbackmesh_cli.mjs doctor",
    "fm:start": "node scripts/feedbackmesh_cli.mjs start",
    "fm:verify": "node scripts/feedbackmesh_cli.mjs verify",
    "sf:init": "node scripts/signalforge_cli.mjs init",
    "sf:doctor": "node scripts/signalforge_cli.mjs doctor",
    "sf:start": "node scripts/signalforge_cli.mjs start",
    "dev": "node apps/api/src/index.js",
    "build": "node -e \"console.log('build placeholder')\"",
    "lint": "node -e \"console.log('lint placeholder')\"",
    "test": "node --test",
    "typecheck": "node -e \"console.log('typecheck placeholder')\""
  }
}
