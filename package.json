{
  "name": "signalforge",
  "private": true,
  "version": "0.1.0",
  "description": "Turn user feedback into decision-ready GitHub issues.",
  "license": "MIT",
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "sf:init": "node scripts/signalforge_cli.mjs init",
    "sf:doctor": "node scripts/signalforge_cli.mjs doctor",
    "sf:start": "node scripts/signalforge_cli.mjs start",
    "dev": "node apps/api/src/index.js",
    "build": "node -e \"console.log('build placeholder')\"",
    "lint": "node -e \"console.log('lint placeholder')\"",
    "test": "node --test",
    "typecheck": "node -e \"console.log('typecheck placeholder')\""
  }
}
